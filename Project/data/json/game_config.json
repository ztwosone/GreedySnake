{
  "version": "1.0.0",
  "grid": {
    "cell_size": 32,
    "width": 40,
    "height": 22,
    "window_scale": 1
  },
  "tick": {
    "base_interval": 0.25
  },
  "snake": {
    "initial_length": 6,
    "min_length": 1,
    "hits_per_segment_loss": 3,
    "no_body_grace_seconds": 10
  },
  "food": {
    "max_count": 3,
    "growth_amount": 1
  },
  "enemy": {
    "max_count": 3,
    "spawn_safe_distance": 3,
    "default_attack_cost": 1,
    "spawn_weights": {
      "wanderer": 50,
      "chaser": 30,
      "bog_crawler": 20
    },
    "max_status_tiles": 100
  },
  "status_effects": {
    "fire": {
      "display_name": "灼烧",
      "aura_damage": 1,
      "entity_damage_interval": 2.0,
      "entity_damage_amount": 1,
      "entity_duration": 6.0,
      "max_layers": 99,
      "tile_duration": 8.0,
      "spread_chance": 0.2,
      "spread_interval": 1.0,
      "color": "#FF4500",
      "visual": {
        "snake_effect": "border_flash",
        "border_color": "#FF4C00",
        "flash_period": 0.5
      },
      "entity_effects": [
        {
          "trigger": "on_interval",
          "interval": 2.0,
          "atoms": [
            { "atom": "damage", "amount_per_layer": 1, "source": "fire" }
          ],
          "pattern": "self"
        }
      ],
      "tile_effects": [
        {
          "trigger": "on_interval",
          "interval": 1.0,
          "atoms": [
            { "atom": "place_tile", "type": "fire", "layer": 1 }
          ],
          "pattern": "neighbors",
          "chance": 0.2
        },
        {
          "trigger": "on_entity_enter",
          "atoms": [
            { "atom": "apply_status", "type": "fire", "layers": 1, "source": "tile" }
          ],
          "pattern": "target"
        }
      ]
    },
    "ice": {
      "display_name": "冰冻",
      "speed_modifier": 0.5,
      "freeze_at_layer": 2,
      "freeze_duration": 2.0,
      "entity_duration": 6.0,
      "max_layers": 2,
      "tile_duration": 12.0,
      "color": "#ADD8E6",
      "visual": {
        "snake_effect": "overlay",
        "overlay_color": "#80B0FF66",
        "freeze_overlay_color": "#E6F0FFB3"
      },
      "entity_effects": [
        {
          "trigger": "on_applied",
          "atoms": [
            { "atom": "modify_speed", "multiplier": 0.5 }
          ],
          "pattern": "self"
        },
        {
          "trigger": "on_layer_reach",
          "layer": 2,
          "atoms": [
            { "atom": "freeze", "duration": 2.0 }
          ],
          "pattern": "self"
        },
        {
          "trigger": "on_removed",
          "atoms": [
            { "atom": "modify_speed", "multiplier": 1.0 }
          ],
          "pattern": "self"
        }
      ],
      "tile_effects": [
        {
          "trigger": "on_entity_enter",
          "atoms": [
            { "atom": "apply_status", "type": "ice", "layers": 1, "source": "tile" }
          ],
          "pattern": "target"
        }
      ]
    },
    "poison": {
      "display_name": "中毒",
      "food_growth_modifier": 0.5,
      "entity_duration": 8.0,
      "toxify_at_layer": 3,
      "toxify_length_penalty": 3,
      "max_layers": 3,
      "tile_duration": 10.0,
      "trail_interval": 3,
      "color": "#006400",
      "visual": {
        "snake_effect": "pulse",
        "overlay_color": "#33CC1A4D",
        "pulse_period": 1.0,
        "pulse_alpha_min": 0.15,
        "pulse_alpha_max": 0.45
      },
      "entity_effects": [
        {
          "trigger": "on_applied",
          "atoms": [
            { "atom": "modify_growth", "multiplier": 0.5 }
          ],
          "pattern": "self"
        },
        {
          "trigger": "on_layer_reach",
          "layer": 3,
          "atoms": [
            { "atom": "damage", "amount": 3, "source": "poison_toxify" },
            { "atom": "remove_status", "type": "poison" }
          ],
          "pattern": "self"
        },
        {
          "trigger": "on_removed",
          "atoms": [
            { "atom": "modify_growth", "multiplier": 1.0 }
          ],
          "pattern": "self"
        }
      ],
      "tile_effects": [
        {
          "trigger": "on_entity_enter",
          "atoms": [
            { "atom": "apply_status", "type": "poison", "layers": 1, "source": "tile" }
          ],
          "pattern": "target"
        }
      ]
    }
  },
  "reactions": {
    "steam": {
      "type_a": "fire",
      "type_b": "ice",
      "display_name": "蒸腾",
      "damage_coefficient": 0.5,
      "radius": 3,
      "enemy_damage": 2,
