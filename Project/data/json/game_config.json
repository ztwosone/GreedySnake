    "toxic_explosion": {
      "type_a": "fire",
      "type_b": "poison",
      "display_name": "毒爆",
      "damage_coefficient": 1.0,
      "radius": 3,
      "enemy_damage": 3,
      "self_hit_count": 2,
      "apply_burn_layers": 2,
      "apply_poison_layers": 1,
      "vfx_color": "#CCFF00",
      "vfx_duration": 0.6,
      "atoms": [
        { "atom": "damage", "formula": "sum_layers", "coefficient": 1.0, "source": "reaction_toxic_explosion" },
        { "atom": "apply_status", "type": "fire", "layers": 2, "source": "reaction_toxic_explosion" },
        { "atom": "apply_status", "type": "poison", "layers": 1, "source": "reaction_toxic_explosion" }
      ]
