        "2": {
          "entity_effects": [
            {
              "trigger": "on_applied",
              "atoms": [
                { "atom": "open_window", "window_id": "lag_tail_active", "duration_ticks": 99999, "rules": { "block_segment_loss": true } }
              ]
            },
            {
              "trigger": "on_removed",
              "atoms": [
                { "atom": "cancel_window", "window_id": "lag_tail_active" }
              ]
            },
            {
              "trigger": "on_segment_loss_deferred",
              "atoms": [
                { "atom": "open_window", "window_id": "lag_tail_delay", "duration_ticks": 3, "cancel_on": "snake_hit_enemy", "on_expire": [{ "atom": "request_segment_loss", "amount": 1 }], "on_cancel": [{ "atom": "modify_hits_taken", "value": -1 }] }
              ]
            }
          ]
        },
        "3": {
          "entity_effects": [
            {
              "trigger": "on_applied",
              "atoms": [
                { "atom": "open_window", "window_id": "lag_tail_active", "duration_ticks": 99999, "rules": { "block_segment_loss": true } }
              ]
            },
            {
              "trigger": "on_removed",
              "atoms": [
                { "atom": "cancel_window", "window_id": "lag_tail_active" }
              ]
            },
            {
              "trigger": "on_segment_loss_deferred",
              "atoms": [
                { "atom": "open_window", "window_id": "lag_tail_delay", "duration_ticks": 3, "cancel_on": "enemy_killed", "on_expire": [{ "atom": "request_segment_loss", "amount": 1 }], "on_cancel": [{ "atom": "modify_hits_taken", "value": -1 }] }
