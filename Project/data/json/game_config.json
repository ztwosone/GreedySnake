    "frozen_plague": {
      "type_a": "ice",
      "type_b": "poison",
      "display_name": "冻疫",
      "radius": 3,
      "enemy_damage": 0,
      "self_hit_count": 0,
      "freeze_duration": 3.0,
      "apply_poison_layers": 1,
      "vfx_color": "#00CED1",
      "vfx_duration": 0.5,
      "atoms": []
    }
  },
